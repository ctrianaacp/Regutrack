# =============================================================
# ReguTrack — Environment Variables
# =============================================================

# ----- PostgreSQL (Docker) -----
POSTGRES_DB=regutrack
POSTGRES_USER=regutrack
POSTGRES_PASSWORD=regutrack_pass

# ----- Database URL (used by SQLAlchemy) -----
# Local dev (Docker):
DATABASE_URL=postgresql://regutrack:regutrack_pass@localhost:5432/regutrack
# SQLite fallback (no Docker needed):
# DATABASE_URL=sqlite:///./regutrack.db

# ----- pgAdmin -----
PGADMIN_EMAIL=admin@regutrack.co
PGADMIN_PASSWORD=admin

# ----- Scraper Settings -----
SCRAPER_REQUEST_DELAY=2.0
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT=30
SCRAPER_USE_PLAYWRIGHT=true

# ----- Scheduler (06:00 Colombia time) -----
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0

# ----- Notifications -----
NOTIFIER_WEBHOOK_URL=
NOTIFIER_SMTP_HOST=
NOTIFIER_SMTP_PORT=587
NOTIFIER_SMTP_USER=
NOTIFIER_SMTP_PASS=
NOTIFIER_EMAIL_FROM=
NOTIFIER_EMAIL_TO=

# ----- Logging -----
LOG_LEVEL=INFO
LOG_DIR=logs

# ----- AI / Adaptive Scraper (Gemini 2.5 Pro) -----
# STEP 1: Set your Google AI Studio API key
GEMINI_API_KEY=
# STEP 2: Leave FALSE until ALL scrapers are tested and working
AI_SCRAPER_ENABLED=false
# STEP 3: Optionally enable predictive DOM change detection
AI_DOM_FINGERPRINT_ENABLED=false
# Model — do not change unless you know what you're doing
AI_MODEL=gemini-2.5-pro-preview-03-25
AI_MAX_HTML_CHARS=80000
